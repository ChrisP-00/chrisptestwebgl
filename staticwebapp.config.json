{
  "globalHeaders": {
    "content-security-policy": "default-src 'self' 'unsafe-eval' 'unsafe-inline'; connect-src 'self' https://*; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'",
    "Cache-Control": "no-cache",
    "X-Content-Type-Options": "nosniff"
  },
  "mimeTypes": {
    ".wasm": "application/wasm",
    ".js": "application/javascript",
    ".data": "application/octet-stream",
    ".json": "application/json",
    ".map": "application/json"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif}", "/css/*", "/*.{css,js,wasm,data}"]
  },
  "routes": [
    {
      "route": "/Build/*.wasm",
      "headers": {
        "Content-Type": "application/wasm",
        "Content-Encoding": "none"
      }
    },
    {
      "route": "/Build/*.data",
      "headers": {
        "Content-Type": "application/octet-stream",
        "Content-Encoding": "none"
      }
    }
  ]
} 